# VertexHub Environment Configuration

# Server
NODE_ENV=development
PORT=3000

# Database
DB_PATH=./data/vertexhub.db

# Logging
LOG_LEVEL=info

# Security
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# API Key (optional - leave empty to disable auth)
API_KEY=
